# SkillSync AI — Environment Variables
# Copy this file to .env and fill in your actual values

# ── AI Provider Keys ─────────────────────────────────────────────
# Gemini (required — get from https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq (optional — get from https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter (optional — get from https://openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Cerebras (optional — get from https://cloud.cerebras.ai)
CEREBRAS_API_KEY=your_cerebras_api_key_here

# ── Auth ─────────────────────────────────────────────────────────
# JWT secret — use a long random string in production
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# Google OAuth client ID (for Google Sign-In button)
# (Frontend Vite needs VITE_ prefix, but we can also use VITE_GOOGLE_CLIENT_ID for Vite and use it in backend as well)
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Optional ─────────────────────────────────────────────────────
# Tesseract OCR binary path (Windows — only needed for image OCR)
# TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe

# ── Frontend Config ──────────────────────────────────────────────
VITE_API_URL=http://localhost:8000

# ── Firebase Configuration ───────────────────────────────────────
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain_here
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id_here
VITE_FIREBASE_APP_ID=your_firebase_app_id_here
VITE_FIREBASE_MEASUREMENT_ID=your_firebase_measurement_id_here
