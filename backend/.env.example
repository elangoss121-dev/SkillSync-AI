# SkillSync AI — Environment Variables
# Copy this file to .env and fill in your actual values

# ── AI Provider Keys ─────────────────────────────────────────────
# Gemini (required — get from https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq (optional — get from https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter (optional — get from https://openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Cerebras (optional — get from https://cloud.cerebras.ai)
CEREBRAS_API_KEY=your_cerebras_api_key_here

# ── Auth ─────────────────────────────────────────────────────────
# JWT secret — use a long random string in production
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# Google OAuth client ID (for Google Sign-In button)
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Optional ─────────────────────────────────────────────────────
# Tesseract OCR binary path (Windows — only needed for image OCR)
# TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe
