# SkillSync AI — Frontend Environment Variables
# Copy this file to .env.local and fill in your actual values

# ── API Connection ───────────────────────────────────────────────
# The base URL of the FastAPI backend.
# In production (e.g. Vercel), you might leave this blank to use relative paths (/api/...)
VITE_API_URL=http://localhost:8000

# ── Auth ─────────────────────────────────────────────────────────
# Google OAuth Client ID for the "Sign In with Google" button.
# Get this from Google Cloud Console -> APIs & Services -> Credentials
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
